<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <!-- Only MacroForge.Core is measured for coverage: MacroForge.App is a thin WinForms
               shell (event handlers wiring buttons to Core) that isn't practical to unit test
               and is instead covered by manual/UI testing. -->
          <Include>[MacroForge.Core]*</Include>
          <ExcludeByAttribute>GeneratedCodeAttribute,CompilerGeneratedAttribute</ExcludeByAttribute>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
